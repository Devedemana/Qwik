# --- APP SETTINGS ---
PORT=3000
NODE_ENV=development

# --- MONGO DATABASE (Local Docker) ---
# Used by the 'mongo' container to set up the DB
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=supersecretpassword
MONGO_DB_NAME=myapp_db

# --- BACKEND CONNECTION ---
# Note: 'mongo' matches the service name in your docker-compose.yml
# Use the credentials defined above
MONGO_URI=mongodb://admin:supersecretpassword@mongo:27017/myapp_db?authSource=admin

# --- SECURITY ---
# Generate a strong 32-character string for development
JWT_SECRET=your_ultra_secure_long_random_jwt_secret_here
JWT_EXPIRES_IN=7d

# --- FLUTTER / CLIENT ORIGINS ---
# This helps configure CORS professionally
CLIENT_ORIGIN=http://localhost:4200